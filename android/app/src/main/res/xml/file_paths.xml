<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- For getApplicationDocumentsDirectory() — where PDFs are saved -->
    <files-path name="app_documents" path="." />
    <!-- For getTemporaryDirectory() — temp catalog PDFs -->
    <cache-path name="temp_files" path="." />
    <!-- For external storage downloads (Android ≤ 9) -->
    <external-path name="external_files" path="." />
</paths>
